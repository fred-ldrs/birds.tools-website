---
/**
 * BaseLayout.astro
 *
 * Props:
 *   lang       – current language code ('en' | 'de' | 'fr')
 *   t          – full translation object for the current language
 *   pageMeta   – optional override for { title, description } (used by sub-pages)
 *   currentPath – path segment after /[lang]/, e.g. '' for home, 'about/' for about
 */
import { LANGUAGES, canonicalUrl } from '../utils/i18n.js';

export interface Props {
  lang: string;
  t: Record<string, any>;
  pageMeta?: { title: string; description: string };
  currentPath?: string;
  footerBirds?: boolean;
}

const { lang, t, pageMeta, currentPath = '', footerBirds = false } = Astro.props;

const title       = pageMeta?.title       ?? t.meta.title;
const description = pageMeta?.description ?? t.meta.description;
const canonical   = canonicalUrl(lang, currentPath);
---
<!doctype html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="referrer" content="no-referrer" />
  <meta
    http-equiv="Content-Security-Policy"
    content="default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self'; script-src 'self'; connect-src 'self';"
  />

  <title>{title}</title>
  <meta name="description" content={description} />

  <!-- Open Graph -->
  <meta property="og:type"        content="website" />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image"       content="/images/og-image.png" />

  <!-- Canonical -->
  <link rel="canonical" href={canonical} />

  <!-- hreflang for every supported language -->
  {LANGUAGES.map((l) => (
    <link rel="alternate" hreflang={l} href={canonicalUrl(l, currentPath)} />
  ))}
  <link rel="alternate" hreflang="x-default" href={canonicalUrl('en', currentPath)} />

  <link rel="stylesheet"          href="/css/styles.css" />
  <link rel="icon"   type="image/png" href="/images/favicon.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/images/favicon.png" />
  <link rel="manifest" href="/manifest.json" />
</head>
<body>

  <!-- Site Navigation -->
  <nav class="site-nav" id="site-nav" aria-label="Main navigation">
    <div class="container">
      <a href={`/${lang}/`} class="site-nav-logo">birds.family</a>

      <!-- Desktop: inline flex row. Mobile: collapsible panel -->
      <div class="nav-menu" id="nav-menu">
        <ul class="site-nav-links">
          <li><a href={`/${lang}/`}                      aria-current={currentPath === ''                     ? 'page' : undefined}>{t.nav.home}</a></li>
          <li><a href={`/${lang}/about/`}                aria-current={currentPath === 'about/'               ? 'page' : undefined}>{t.nav.about}</a></li>
          <li><a href={`/${lang}/printables/coloring/`}  aria-current={currentPath === 'printables/coloring/' ? 'page' : undefined}>{t.nav.coloring}</a></li>
        </ul>

        <div class="lang-switcher" aria-label="Language switcher">
          {LANGUAGES.map((l) => (
            <a
              href={`/${l}/${currentPath}`}
              aria-current={l === lang ? 'true' : undefined}
              hreflang={l}
              class:list={['lang-link', { active: l === lang }]}
            >
              {l.toUpperCase()}
            </a>
          ))}
        </div>
      </div>

      <!-- Hamburger (mobile only) -->
      <button class="nav-toggle" id="nav-toggle" aria-expanded="false" aria-controls="nav-menu" aria-label="Menu">
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
          <rect class="bar bar-top" x="0" y="4"  width="22" height="2" rx="1" fill="currentColor"/>
          <rect class="bar bar-mid" x="0" y="10" width="22" height="2" rx="1" fill="currentColor"/>
          <rect class="bar bar-bot" x="0" y="16" width="22" height="2" rx="1" fill="currentColor"/>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Page content injected here -->
  <slot />

  <!-- Footer -->
  <footer class="footer">
    <div class="container">
      {footerBirds && (
        <div class="footer-birds">
          <img src="/images/header_var2_cut.png" alt={t.footer.footerImgAlt} aria-hidden="true" />
        </div>
      )}
      <p class="footer-tagline">{t.footer.tagline}</p>
      <nav class="footer-links">
        <a href={`/${lang}/privacy/`}>{t.footer.privacy}</a>
        <span class="separator">·</span>
        <a href={`/${lang}/imprint/`}>{t.footer.imprint}</a>
      </nav>
      <p class="footer-copyright">{t.footer.copyright}</p>
      <p class="footer-copyright">
        {t.footer.madeBy} <a href="https://lueders.app" target="_blank" rel="noopener noreferrer">lueders.app</a>
        — {t.footer.poweredBy} <a href="https://lueders.solutions" target="_blank" rel="noopener noreferrer">lueders.solutions</a>
      </p>
    </div>
  </footer>

  <script>
    const btn  = document.getElementById('nav-toggle') as HTMLButtonElement | null;
    const menu = document.getElementById('nav-menu');
    const nav  = document.getElementById('site-nav');

    btn?.addEventListener('click', () => {
      const isOpen = menu?.classList.toggle('open') ?? false;
      btn.setAttribute('aria-expanded', String(isOpen));
    });

    // Close when clicking outside the nav
    document.addEventListener('click', (e) => {
      if (nav && !nav.contains(e.target as Node)) {
        menu?.classList.remove('open');
        btn?.setAttribute('aria-expanded', 'false');
      }
    });

    // Close when a nav link is clicked (navigating to new page)
    menu?.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        menu.classList.remove('open');
        btn?.setAttribute('aria-expanded', 'false');
      });
    });
  </script>

</body>
</html>

<style>
  /* ── Language Switcher ─────────────────────────────────────── */
  .lang-switcher {
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }

  .lang-link {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    color: var(--gray-medium);
    text-decoration: none;
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
    transition: color 0.2s, background 0.2s;
  }

  .lang-link:hover,
  .lang-link.active {
    color: var(--mint-primary);
    background: var(--mint-bg-darker);
  }

  /* ── Nav menu (desktop: inline flex) ───────────────────────── */
  .nav-menu {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  /* ── Hamburger button (hidden on desktop) ───────────────────── */
  .nav-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.35rem;
    color: var(--gray-dark);
    border-radius: 6px;
    line-height: 0;
    transition: background 0.2s, color 0.2s;
  }
  .nav-toggle:hover {
    background: var(--mint-bg-darker);
    color: var(--mint-primary);
  }

  /* Hamburger → X animation */
  .bar {
    transform-origin: 11px 11px;
    transition: transform 0.25s ease, opacity 0.2s ease;
  }
  .nav-toggle[aria-expanded="true"] .bar-top {
    transform: translateY(6px) rotate(45deg);
  }
  .nav-toggle[aria-expanded="true"] .bar-mid {
    opacity: 0;
    transform: scaleX(0);
  }
  .nav-toggle[aria-expanded="true"] .bar-bot {
    transform: translateY(-6px) rotate(-45deg);
  }
</style>

<style is:global>
  /* ── Mobile nav ─────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .nav-toggle {
      display: flex !important;
      align-items: center;
      justify-content: center;
    }

    .nav-menu {
      display: none;
      position: absolute;
      top: 52px;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      background: rgba(255, 255, 255, 0.98);
      border-bottom: 1px solid var(--gray-light);
      padding: 0.5rem 1rem 1rem;
      box-shadow: 0 6px 16px rgba(0, 0, 0, 0.08);
      z-index: 99;
    }

    .nav-menu.open {
      display: flex;
    }

    .site-nav-links {
      flex-direction: column;
      gap: 0;
    }

    .site-nav-links a {
      display: block;
      padding: 0.75rem 0.5rem;
      font-size: 1rem;
      border-radius: 6px;
    }

    .lang-switcher {
      border-top: 1px solid var(--gray-light);
      padding-top: 0.75rem;
      margin-top: 0.25rem;
      gap: 0.25rem;
    }

    .lang-link {
      font-size: 0.9rem;
      padding: 0.3rem 0.6rem;
    }
  }
</style>
